		<script>

      (function () 
      {
        const zuid = "60040390550";
        const userName = "Joshua";
        const userImage = 'https://contacts.zoho.in/file?ID=60040390550&t=user&exp=6000&fs=thumb&nocache=1773723773618';
        const paths = window.location.pathname.split('/');
        const contentId = paths.includes('view') ? paths[3] : undefined;
        const uploadUrl = "https://upload.zoho.in"; // No I18N
        const contactsUrl = "https://contacts.zoho.in"; // No I18N
        const session = new VODDemoSession({zuid, userName, userImage, uploadUrl, contactsUrl});

        vodDemo._cdnDomain = 'static.zohocdn.com'; // No I18N
        vodDemo.setVodDemoSession(session);
				vodDemo.init(contentId, session);
      })()
			
